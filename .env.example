# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# ─── Gemini API (free) ────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Gmail (sender) ───────────────────────────────────────────────────────────
# The Gmail account that SENDS the morning summary (can be your own Gmail)
SENDER_EMAIL=your_gmail@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get one:
#   1. Go to myaccount.google.com/security
#   2. Enable 2-Step Verification (required)
#   3. Search "App passwords" → Create one → name it "job-pipeline"
#   4. Copy the 16-character password here (no spaces)
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# ─── Google Drive ─────────────────────────────────────────────────────────────
# The ID of the Google Drive folder where cover letters are stored
# How to get it: open the folder in Drive, copy the ID from the URL
#   https://drive.google.com/drive/folders/THIS_PART_IS_THE_ID
DRIVE_FOLDER_ID=your_drive_folder_id_here

# ─── Recipient ────────────────────────────────────────────────────────────────
# Who receives the morning summary email (Ashlee's email)
RECIPIENT_EMAIL=ashleerthomas@gmail.com
